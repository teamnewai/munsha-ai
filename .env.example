# ===== Supabase (مشروع mulki-reos) =====
# عند ضبط هذه المفاتيح في Vercel تتحوّل لوحة القيادة تلقائياً لقراءة البيانات الحيّة.
# الرابط: https://fgincdqvhnuarqcdnsfe.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://fgincdqvhnuarqcdnsfe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVICE_ROLE سرّي — يُستخدم في الخادم فقط لقراءة لوحة القيادة (يتجاوز RLS). أضِفه في Vercel فقط.
SUPABASE_SERVICE_ROLE_KEY=

# ===== App =====
# الدومين الأساسي للموقع (للـ SEO/Sitemap/الروابط). للإنتاج: https://mulkios.vercel.app
NEXT_PUBLIC_APP_URL=https://mulkios.vercel.app
NEXT_PUBLIC_APP_NAME=مُلكي

# ===== AI (Edge Functions) =====
OPENAI_API_KEY=

# ===== Payments — REOS: المنصة تُسجّل ولا تحتفظ بالأموال =====
# المزوّد النشط: stripe | moyasar | tap | hyperpay
PAYMENT_ACTIVE_PROVIDER=moyasar
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=
